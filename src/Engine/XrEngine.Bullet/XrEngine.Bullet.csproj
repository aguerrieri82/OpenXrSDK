<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>

		<NativeFolder>Debug</NativeFolder>
	</PropertyGroup>

	<ItemGroup Condition="'$(IsAndroid)' == 'false' AND '$(BulletLink)' != 'PreBuilt'">
		<Content Include="..\XrEngine.Bullet.Native\bin\$(NativePlatform)\$(NativeFolder)\*" CopyToOutputDirectory="PreserveNewest" Link="runtimes/win-x64/native/%(Filename)%(Extension)" />
		<Content Include="..\XrEngine.Bullet.Native\bin\$(NativePlatform)\$(NativeFolder)\*" CopyToOutputDirectory="PreserveNewest" Link="%(Filename)%(Extension)" />
		<Content Include="..\XrEngine.Bullet.Native\libs\arm64-v8a\*.so" CopyToOutputDirectory="PreserveNewest" Link="runtimes/android-arm64/native/%(Filename)%(Extension)" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\XrEngine.Bullet.Native\XrEngine.Bullet.Native.vcxproj" />
		<ProjectReference Include="..\XrEngine.Core\XrEngine.Core.csproj" />
	</ItemGroup>

</Project>
